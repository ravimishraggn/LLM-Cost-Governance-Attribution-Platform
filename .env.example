# Copy to `.env` and fill in. The gateway runs in MOCK mode by default so you
# can demo the full pipeline without any real provider keys or spend.

# --- Gateway behaviour ---
# When true, providers return deterministic fake responses (no real API calls,
# no cost). Set to false once you have real keys configured below.
GATEWAY_MOCK_MODE=true

# --- Storage ---
# Any SQLAlchemy URL. Defaults to a local SQLite file.
# Postgres example: postgresql+psycopg://user:pass@localhost:5432/llm_gov
DATABASE_URL=sqlite:///./llm_gov.db

# --- Provider credentials (only needed when GATEWAY_MOCK_MODE=false) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS Bedrock uses the standard boto3 credential chain.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
